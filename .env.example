# Path to the SQLite database file (created on first run).
DATABASE_PATH=./data/plate.db

# Better Auth — authentication is SSO-only via Authentik (OIDC).
# Secret used to sign sessions/cookies. Generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=change-me
# Public origin of this app (used for cookies + OAuth redirects). In production
# this must be the https URL behind your reverse proxy, e.g. https://plate.example.com
BETTER_AUTH_URL=http://localhost:5173

# Authentik OIDC provider. Discovery URL is the provider's well-known endpoint,
# typically: https://authentik.example.com/application/o/<app-slug>/.well-known/openid-configuration
# Register this app's callback in Authentik as:
#   <BETTER_AUTH_URL>/api/auth/oauth2/callback/authentik
OIDC_DISCOVERY_URL=https://authentik.example.com/application/o/plate/.well-known/openid-configuration
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Port the Node server listens on (production `npm start`).
PORT=3000
